<mujoco model="arm4_demo">
  <compiler angle="radian" inertiafromgeom="true"/>
  <option timestep="0.003" gravity="0 0 -9.81" integrator="RK4"/>

  <default>
    <joint damping="1.2" armature="0.08" limited="true"/>
    <geom friction="0.8 0.1 0.1" rgba="0.2 0.6 0.9 1"/>
    <position kp="35"/>
  </default>

  <worldbody>
    <light pos="0 0 4"/>
    <geom name="floor" type="plane" size="4 4 0.1" rgba="0.95 0.95 0.98 1"/>

    <body name="base" pos="0 0 0.4">
      <geom type="cylinder" size="0.18 0.16" rgba="0.3 0.3 0.35 1"/>
      <joint name="j0" type="hinge" axis="0 0 1" range="-2.6 2.6"/>

      <body name="link1" pos="0 0 0.2">
        <geom type="capsule" fromto="0 0 0 0 0 1.0" size="0.06"/>
        <joint name="j1" type="hinge" axis="0 1 0" range="-2.6 2.6"/>

        <body name="link2" pos="0 0 1.0">
          <geom type="capsule" fromto="0 0 0 0 0 0.85" size="0.05" rgba="0.25 0.7 0.95 1"/>
          <joint name="j2" type="hinge" axis="0 1 0" range="-2.6 2.6"/>

          <body name="link3" pos="0 0 0.85">
            <geom type="capsule" fromto="0 0 0 0 0 0.48" size="0.045" rgba="0.1 0.55 0.85 1"/>
            <joint name="j3" type="hinge" axis="0 1 0" range="-2.6 2.6"/>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <position name="a0" joint="j0"/>
    <position name="a1" joint="j1"/>
    <position name="a2" joint="j2"/>
    <position name="a3" joint="j3"/>
  </actuator>
</mujoco>
